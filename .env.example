# Base PostgreSQL centrale (la valeur reste vide tant que PostgreSQL n'est pas configuré).
DATABASE_URL=
# Exemple local uniquement : DATABASE_URL=postgresql://resaleos:resaleos_dev@127.0.0.1:5432/resaleos?schema=public

# GPT-5.6 via Vercel AI Gateway : sourcing, vision, annonce, audit et négociation.
RESALE_AI_MODEL=openai/gpt-5.6
# Nécessaire hors Vercel. Sur un déploiement Vercel lié, l'OIDC peut l'éviter.
AI_GATEWAY_API_KEY=

# GPT Image 2 utilise l'API Images OpenAI directement pour les éditions multi-références.
# La clé API est distincte d'un abonnement ChatGPT et reste uniquement côté serveur.
OPENAI_API_KEY=
RESALE_IMAGE_MODEL=gpt-image-2

# Stockage public des images d'annonce validées. Une intégration Vercel Blob liée
# fournit généralement BLOB_READ_WRITE_TOKEN automatiquement.
BLOB_READ_WRITE_TOKEN=
BLOB_STORE_ID=

# Facultatif en local, fortement recommandé dès que l'application est publique.
# Le même secret est saisi une fois dans l'interface pour les appels web.
RESALE_AUTOMATION_SECRET=change-me-with-a-long-random-value

# Telegram — créer le bot avec @BotFather, puis enregistrer le webhook.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ALLOWED_CHAT_ID=

# Stockage temporaire des conversations Telegram (Upstash Redis REST).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Seuils appliqués si le texte Telegram ne précise pas "profit 20" ou "ROI 50".
RESALE_DEFAULT_MIN_PROFIT=15
RESALE_DEFAULT_MIN_ROI=40

# Adaptateur facultatif/legacy vers un autre outil de traitement d'images.
# Il reçoit un POST JSON et doit répondre avec { "images": ["https://..."] }.
RESALE_IMAGE_PROCESSOR_URL=
RESALE_IMAGE_PROCESSOR_SECRET=
